{
    "tag": "my-node-service",
    "architecture": "linux/amd64",
    "resources": {
        "at_init": { "mem_limit": 134217728, "disk_space": 1073741824 },
        "at_most": { "mem_limit": 536870912, "disk_space": 5368709120 }
    },
    "init": { "entry_path": ["app", "start.sh"] },
    "api": [
        {
            "port": 3000,
            "transport": "tcp",
            "protocol": ["http1.1", "rest"],
            "gas_amount_per_call": { "POST /process": 80, "GET /health": 5 }
        }
    ]
}
