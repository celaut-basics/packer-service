#!/usr/bin/env bash
# pack-service [dir-or-name] — zip a project and POST it to the local packer
# running inside this same microVM, then save <service-id>.celaut.bee next to the
# project. Prints the deterministic X-Service-Id returned by the packer.
#
#   pack-service                 # pack the current directory
#   pack-service my-service      # pack /workspace/my-service
#   pack-service /path/to/proj   # pack an absolute path
set -euo pipefail

WORKSPACE="${WORKSPACE_DIR:-/workspace}"
PACKER="${PACKER_URL:-http://127.0.0.1:8080}"

arg="${1:-.}"
if [ -d "$arg" ]; then proj="$arg"; else proj="$WORKSPACE/$arg"; fi
[ -d "$proj" ] || { echo "no such project: $arg"; exit 1; }
proj="$(cd "$proj" && pwd)"

# The packer accepts config at the project root (Option 2) or under .service/.
if [ ! -f "$proj/service.json" ] && [ ! -f "$proj/.service/service.json" ]; then
  echo "error: $proj has no service.json (root or .service/)"; exit 1
fi
if [ ! -f "$proj/Dockerfile" ] && [ ! -f "$proj/.service/Dockerfile" ]; then
  echo "error: $proj has no Dockerfile (root or .service/)"; exit 1
fi

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
zip="$tmp/project.zip"
( cd "$proj" && zip -qr "$zip" . \
    -x '.git/*' 'node_modules/*' 'target/*' 'build/*' \
       'vendor/*' '__pycache__/*' '*.pyc' '*.celaut.bee' 'service.bee' )

hdr="$tmp/headers.txt"
out="$tmp/response.bin"
echo "Packing $proj ..."
code="$(curl -sS -D "$hdr" -o "$out" -w '%{http_code}' \
  --max-time 1800 -H 'Content-Type: application/zip' \
  --data-binary @"$zip" "$PACKER/pack")"

if [ "$code" != "200" ]; then
  echo "pack failed (HTTP $code):"
  cat "$out" 2>/dev/null || true
  echo
  exit 1
fi

sid="$(awk -F': ' 'tolower($1)=="x-service-id"{gsub(/\r/,"",$2);print $2}' "$hdr")"
final="$proj/${sid:-service}.celaut.bee"
mv "$out" "$final"
echo "OK   service-id: ${sid:-<unknown>}"
echo "Wrote $final"
