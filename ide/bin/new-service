#!/usr/bin/env bash
# new-service <language> [name] — scaffold a packer-ready service from a template.
#
# Copies the chosen language template into the workspace and ALWAYS drops a copy
# of the Celaut service configuration guide (SERVICE_CONFIG_GUIDE.md) inside it,
# both at the project root and under .service/.
set -euo pipefail

TEMPLATES="${TEMPLATES_DIR:-/opt/ide/templates}"
GUIDE="${SERVICE_GUIDE:-/opt/ide/SERVICE_CONFIG_GUIDE.md}"
WORKSPACE="${WORKSPACE_DIR:-/workspace}"

lang="${1:-}"
name="${2:-}"

list_langs() { ls -1 "$TEMPLATES" 2>/dev/null | sed 's/^/  - /'; }

if [ -z "$lang" ]; then
  echo "usage: new-service <language> [name]"
  echo "available templates:"; list_langs
  exit 2
fi
if [ ! -d "$TEMPLATES/$lang" ]; then
  echo "unknown template: '$lang'"
  echo "available templates:"; list_langs
  exit 2
fi

name="${name:-my-${lang}-service}"
dest="$WORKSPACE/$name"
if [ -e "$dest" ]; then
  echo "error: '$dest' already exists — pick another name."
  exit 1
fi

cp -r "$TEMPLATES/$lang" "$dest"

# Always include the configuration guide inside the generated service.
if [ -f "$GUIDE" ]; then
  cp "$GUIDE" "$dest/SERVICE_CONFIG_GUIDE.md"
  mkdir -p "$dest/.service"
  cp "$GUIDE" "$dest/.service/SERVICE_CONFIG_GUIDE.md"
fi

echo "Created $dest (from '$lang' template)"
echo
echo "Next:"
echo "  1. Edit the source under $dest/"
echo "  2. Adjust $dest/service.json (entrypoint, ports, resources)"
echo "  3. Pack it:   pack-service \"$name\""
