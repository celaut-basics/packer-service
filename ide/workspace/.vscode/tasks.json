{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "New service from template",
      "type": "shell",
      "command": "new-service ${input:language} ${input:serviceName}",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "Pack this service",
      "type": "shell",
      "command": "pack-service ${input:packTarget}",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "language",
      "type": "pickString",
      "description": "Select a language template",
      "options": [
        "python",
        "go",
        "rust",
        "node-express",
        "node-typescript",
        "java-spring",
        "java-gradle",
        "php-laravel"
      ],
      "default": "python"
    },
    {
      "id": "serviceName",
      "type": "promptString",
      "description": "Name for the new service folder",
      "default": "my-service"
    },
    {
      "id": "packTarget",
      "type": "promptString",
      "description": "Project folder to pack (relative to this workspace)",
      "default": "my-service"
    }
  ]
}
